#include <stdio.h>
int main()
 {
    float basic, da, hra, gross;
    printf("Enter Basic Pay: ");
    scanf("%f", &basic);
    da = 0.40 * basic;   
    hra = 0.10 * basic;  
    gross = basic + da + hra + 2000; 
    printf("DA (40%%) = %f\n", da);
    printf("HRA (10%%) = %f\n", hra);
    printf("Gross Salary = %f\n", gross);
    return 0;
}
