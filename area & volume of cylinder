#include <stdio.h>
int main()
 {
    float r, h, area, volume;
    float pi = 3.14159;
    printf("Enter radius of the cylinder: ");
    scanf("%f", &r);
    printf("Enter height of the cylinder: ");
    scanf("%f", &h);
    area = 2 * pi * r * (r + h);
    volume = pi * r * r * h;
    printf("Total Surface Area of Cylinder = %f\n", area);
    printf("Volume of Cylinder = %f\n", volume);
    return 0;
}
