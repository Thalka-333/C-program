#include <stdio.h>
int main()
 {
    float cp, sp;
    printf("Enter Cost Price: ");
    scanf("%f", &cp);
    printf("Enter Selling Price: ");
    scanf("%f", &sp);
    if (sp > cp)
    {
        printf("Profit = %f\n", sp - cp);
    } else if (cp > sp) {
        printf("Loss = %f\n", cp - sp);
    } else {
        printf("No Profit, No Loss.\n");
    }
    return 0;
}
