#include <stdio.h>
int main()
{
    int n;
    int a = 0; 
    int b = 0; 
    int c[n];
    if (scanf("%d", &n) != 1 || n <= 0)
    {
        return 0;
    }
    for (int i = 0; i < n; i++)
    {
        scanf("%d", &c[i]);
    }
    for (int i = 0; i < n; i++)
    {
        if (c[i] % 2 == 0) 
        {
            a++;
            if (a > b) 
            {
                b = a;
            }
        } 
        else 
        {
            a = 0; 
        }
    }
    printf("%d\n", b);
    return 0;
}
